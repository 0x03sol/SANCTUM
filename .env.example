# ============================================================
#  Sanctum — Ritual Chain environment (TEMPLATE / safe to share)
#  Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ---- Chain (verified, do not change) ----
RITUAL_CHAIN_ID=1979
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws
RITUAL_EXPLORER=https://explorer.ritualfoundation.org

# ---- Deployer wallet ----
# Address is safe to share. Paste it here.
DEPLOYER_ADDRESS=0xYOUR_WALLET_ADDRESS
# Private key is SECRET. Put it ONLY in .env (never .env.example, never chat).
# Format: 0x-prefixed 64 hex chars.
PRIVATE_KEY=

# ---- System contracts (verified, do not change) ----
RITUAL_WALLET=0x532F0dF0896F353d8C3DD8cc134e8129DA2a3948
ASYNC_JOB_TRACKER=0xC069FFCa0389f44eCA2C626e55491b0ab045AEF5
